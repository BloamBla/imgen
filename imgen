#!/usr/bin/env bash
# imgen launcher — passes through to the venv-installed `imgen` entry point.
#
# Why a shim?
#   1. Existing colleagues have `alias imgen=~/imgen/imgen` from bootstrap.sh.
#      v0.2.0 moved the code into a Python package, so this file stays at the
#      same path and proxies to the real entry point.
#   2. Self-heals the migration: if .venv/bin/imgen is missing (first run
#      right after `imgen upgrade` pulled v0.2.0 without yet reinstalling
#      the package), runs `pip install -e .` once and continues.
#   3. Sets IMGEN_HOME so the Python package knows where the git checkout
#      lives (used by `imgen upgrade` for git pull + pip reinstall).
#
# Pipx-installed users don't see this file — their `imgen` is in PATH from
# ~/.local/bin/ and runs the entry point directly.

set -euo pipefail

DIR="$(dirname "$(readlink -f "$0" 2>/dev/null || python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")")"
export IMGEN_HOME="$DIR"

if [ ! -d "$DIR/.venv" ]; then
  echo "❌ venv missing at $DIR/.venv" >&2
  echo "   Run: $DIR/bootstrap.sh" >&2
  exit 3
fi

VENV_IMGEN="$DIR/.venv/bin/imgen"
if [ ! -x "$VENV_IMGEN" ]; then
  echo "⚠️  imgen package not in venv — installing (one-time, ~5s)..." >&2
  "$DIR/.venv/bin/pip" install --quiet -e "$DIR" >&2
fi

exec "$VENV_IMGEN" "$@"
